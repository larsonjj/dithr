{
  "title": "Spritemark",
  "author": "dithr",
  "version": "1.0.0",
  "description": "Bunnymark-style sprite benchmark using Kenney 1-bit platformer characters",
  "display": {
    "width": 320,
    "height": 180,
    "scale": 3
  },
  "timing": {
    "fps": 60,
    "ups": 60
  },
  "sprites": {
    "sheet": "assets/sprites/spritesheet.png",
    "tileW": 16,
    "tileH": 16
  },
  "audio": {
    "channels": 8
  },
  "input": {
    "default_mappings": {}
  },
  "code": "dist/main.js",
  "buildCommand": "npx esbuild src/main.ts --bundle --format=esm --target=es2020 --outfile=dist/main.js",
  "maps": []
}
