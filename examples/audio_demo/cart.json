{
  "title": "Audio Demo",
  "author": "dithr",
  "version": "1.0.0",
  "description": "Demonstrates SFX playback, music, volume control, and fade",
  "display": {
    "width": 320,
    "height": 180,
    "scale": 3
  },
  "timing": {
    "fps": 60
  },
  "sprites": {
    "tileW": 8,
    "tileH": 8
  },
  "audio": {
    "channels": 8
  },
  "input": {
    "default_mappings": {}
  },
  "code": "dist/main.js",
  "buildCommand": "npx esbuild src/main.ts --bundle --format=esm --target=es2020 --outfile=dist/main.js"
}
