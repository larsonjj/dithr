{
  "title": "Persistence Demo",
  "author": "dithr",
  "version": "1.0.0",
  "description": "Demonstrates cart.save/load, cart.dset/dget, and metadata",
  "display": {
    "width": 320,
    "height": 180,
    "scale": 3
  },
  "timing": {
    "fps": 60
  },
  "sprites": {
    "sheet": "assets/sprites/spritesheet.png",
    "tileW": 8,
    "tileH": 8
  },
  "audio": {
    "channels": 8
  },
  "input": {
    "default_mappings": {}
  },
  "code": "dist/main.js",
  "buildCommand": "npx esbuild src/main.ts --bundle --format=esm --target=es2020 --outfile=dist/main.js",
  "maps": []
}
