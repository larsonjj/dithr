{
    "name": "dithr-example-editor",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "lint": "eslint src/",
        "lint:fix": "eslint --fix src/",
        "format": "prettier --write src/",
        "format:check": "prettier --check src/",
        "build": "esbuild src/main.ts --bundle --format=esm --target=es2020 --outfile=dist/main.js",
        "typecheck": "tsc --noEmit"
    },
    "devDependencies": {
        "@eslint/js": "^9.0.0",
        "eslint": "^9.0.0",
        "eslint-config-prettier": "^9.0.0",
        "prettier": "^3.0.0",
        "typescript": "^5.0.0",
        "typescript-eslint": "^8.0.0",
        "esbuild": "^0.24.0"
    }
}
