{
  "title": "Gauntlet",
  "author": "dithr",
  "version": "1.0.0",
  "description": "A top-down dungeon crawler inspired by NES Gauntlet",
  "display": {
    "width": 320,
    "height": 180,
    "scale": 3
  },
  "timing": {
    "fps": 60,
    "ups": 60
  },
  "sprites": {},
  "audio": {
    "channels": 8
  },
  "input": {
    "default_mappings": {
      "left": [
        "KEY_LEFT",
        "KEY_A",
        "PAD_LEFT"
      ],
      "right": [
        "KEY_RIGHT",
        "KEY_D",
        "PAD_RIGHT"
      ],
      "up": [
        "KEY_UP",
        "KEY_W",
        "PAD_UP"
      ],
      "down": [
        "KEY_DOWN",
        "KEY_S",
        "PAD_DOWN"
      ],
      "attack": [
        "KEY_Z",
        "KEY_SPACE",
        "PAD_A"
      ],
      "use": [
        "KEY_X",
        "PAD_B"
      ]
    }
  },
  "code": "dist/main.js",
  "buildCommand": "npx esbuild src/main.ts --bundle --format=esm --target=es2020 --outfile=dist/main.js",
  "maps": []
}
