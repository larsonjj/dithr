{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 22,
    "patch": 1
  },
  "configurePresets": [
    {
      "name": "debug",
      "displayName": "Debug",
      "description": "Debug build with default 320x180 resolution",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "MVN_DEV_BUILD": "ON"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "description": "Optimised release build",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "retro",
      "displayName": "Retro (128x128)",
      "description": "Tiny square framebuffer for PICO-8 style games",
      "inherits": "debug",
      "binaryDir": "${sourceDir}/build/retro",
      "cacheVariables": {
        "MVN_FB_WIDTH": "128",
        "MVN_FB_HEIGHT": "128",
        "MVN_WINDOW_SCALE": "4"
      }
    },
    {
      "name": "wide",
      "displayName": "Wide (384x216)",
      "description": "Wider 16:9 framebuffer",
      "inherits": "debug",
      "binaryDir": "${sourceDir}/build/wide",
      "cacheVariables": {
        "MVN_FB_WIDTH": "384",
        "MVN_FB_HEIGHT": "216",
        "MVN_WINDOW_SCALE": "3"
      }
    },
    {
      "name": "wasm",
      "displayName": "WASM Release",
      "description": "Emscripten WebAssembly release build",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/wasm",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_TOOLCHAIN_FILE": "$env{EMSDK}/upstream/emscripten/cmake/Modules/Platform/Emscripten.cmake",
        "MVN_BUILD_EXAMPLES": "OFF",
        "MVN_BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "wasm-dev",
      "displayName": "WASM Debug",
      "description": "Emscripten WebAssembly debug build",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/wasm-dev",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_TOOLCHAIN_FILE": "$env{EMSDK}/upstream/emscripten/cmake/Modules/Platform/Emscripten.cmake",
        "MVN_BUILD_EXAMPLES": "OFF",
        "MVN_BUILD_TESTS": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "retro",
      "configurePreset": "retro"
    },
    {
      "name": "wide",
      "configurePreset": "wide"
    },
    {
      "name": "wasm",
      "configurePreset": "wasm"
    },
    {
      "name": "wasm-dev",
      "configurePreset": "wasm-dev"
    }
  ]
}
