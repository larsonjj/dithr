{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 22,
    "patch": 1
  },
  "configurePresets": [
    {
      "name": "debug",
      "displayName": "Debug",
      "description": "Debug build with default 320x180 resolution",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "DTR_DEV_BUILD": "ON",
        "BUILD_SHARED_LIBS": "OFF"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "description": "Optimised release build with LTO",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "DTR_ENABLE_LTO": "ON"
      }
    },
    {
      "name": "wasm",
      "displayName": "WASM Release",
      "description": "Emscripten WebAssembly release build",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/wasm",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_TOOLCHAIN_FILE": "$env{EMSDK}/upstream/emscripten/cmake/Modules/Platform/Emscripten.cmake",
        "DTR_BUILD_EXAMPLES": "OFF",
        "DTR_BUILD_TESTS": "OFF",
        "DTR_WASM_CART_DIR": "${sourceDir}/examples/hello_world"
      }
    },
    {
      "name": "wasm-dev",
      "displayName": "WASM Debug",
      "description": "Emscripten WebAssembly debug build",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/wasm-dev",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_TOOLCHAIN_FILE": "$env{EMSDK}/upstream/emscripten/cmake/Modules/Platform/Emscripten.cmake",
        "DTR_BUILD_EXAMPLES": "OFF",
        "DTR_BUILD_TESTS": "OFF",
        "DTR_WASM_CART_DIR": "${sourceDir}/examples/hello_world"
      }
    },
    {
      "name": "asan",
      "displayName": "Debug + Sanitizers",
      "description": "Debug build with AddressSanitizer and UndefinedBehaviorSanitizer",
      "binaryDir": "${sourceDir}/build/asan",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "DTR_DEV_BUILD": "ON",
        "DTR_ENABLE_ASAN": "ON",
        "DTR_ENABLE_UBSAN": "ON",
        "BUILD_SHARED_LIBS": "OFF"
      }
    },
    {
      "name": "coverage",
      "displayName": "Debug + Coverage",
      "description": "Debug build with code coverage instrumentation (GCC/Clang only)",
      "binaryDir": "${sourceDir}/build/coverage",
      "condition": {
        "type": "notEquals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "DTR_DEV_BUILD": "ON",
        "DTR_ENABLE_COVERAGE": "ON",
        "BUILD_SHARED_LIBS": "OFF"
      }
    },
    {
      "name": "pgo-generate",
      "displayName": "PGO Generate",
      "description": "Release build that generates profile data (GCC/Clang only)",
      "binaryDir": "${sourceDir}/build/pgo-generate",
      "condition": {
        "type": "notEquals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "DTR_ENABLE_PGO_GENERATE": "ON",
        "DTR_ENABLE_LTO": "ON"
      }
    },
    {
      "name": "pgo-use",
      "displayName": "PGO Use",
      "description": "Release build that uses previously collected profile data (GCC/Clang only)",
      "binaryDir": "${sourceDir}/build/pgo-use",
      "condition": {
        "type": "notEquals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "DTR_ENABLE_PGO_USE": "ON",
        "DTR_PGO_PROFILE_DIR": "${sourceDir}/build/pgo-generate",
        "DTR_ENABLE_LTO": "ON"
      }
    },
    {
      "name": "fuzz",
      "displayName": "Fuzzing",
      "description": "Build fuzz targets with libFuzzer (Clang only)",
      "binaryDir": "${sourceDir}/build/fuzz",
      "condition": {
        "type": "notEquals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_COMPILER": "clang",
        "DTR_BUILD_FUZZ": "ON",
        "DTR_BUILD_TESTS": "OFF",
        "DTR_BUILD_EXAMPLES": "OFF",
        "BUILD_SHARED_LIBS": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "wasm",
      "configurePreset": "wasm"
    },
    {
      "name": "wasm-dev",
      "configurePreset": "wasm-dev"
    },
    {
      "name": "asan",
      "configurePreset": "asan"
    },
    {
      "name": "coverage",
      "configurePreset": "coverage"
    },
    {
      "name": "pgo-generate",
      "configurePreset": "pgo-generate"
    },
    {
      "name": "pgo-use",
      "configurePreset": "pgo-use"
    },
    {
      "name": "fuzz",
      "configurePreset": "fuzz"
    }
  ],
  "testPresets": [
    {
      "name": "debug",
      "configurePreset": "debug",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "release",
      "configurePreset": "release",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "asan",
      "configurePreset": "asan",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
