{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Configure (Debug)",
      "type": "shell",
      "command": "cmake --preset debug",
      "problemMatcher": []
    },
    {
      "label": "Build (Debug)",
      "type": "shell",
      "command": "cmake --build build/debug --config Debug",
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": "$msCompile",
      "dependsOn": "Configure (Debug)"
    },
    {
      "label": "Test (Debug)",
      "type": "shell",
      "command": "ctest --output-on-failure -C Debug",
      "options": { "cwd": "${workspaceFolder}/build/debug" },
      "group": { "kind": "test", "isDefault": true },
      "problemMatcher": [],
      "dependsOn": "Build (Debug)"
    },
    {
      "label": "WASM: Build",
      "type": "shell",
      "command": "cmake --build build/wasm",
      "group": "build",
      "problemMatcher": "$gcc",
      "dependsOn": "WASM: Configure"
    },
    {
      "label": "WASM: Configure",
      "type": "shell",
      "command": "cmake --preset wasm -DMVN_WASM_CART_DIR=${input:wasmCart}",
      "problemMatcher": []
    },
    {
      "label": "WASM: Run",
      "type": "shell",
      "command": "node tools/serve-wasm.js",
      "dependsOn": "WASM: Build",
      "problemMatcher": [],
      "isBackground": true
    }
  ],
  "inputs": [
    {
      "id": "wasmCart",
      "type": "pickString",
      "description": "Select cart to embed in WASM build",
      "options": ["", "${workspaceFolder}/examples/hello_world"],
      "default": ""
    }
  ]
}
