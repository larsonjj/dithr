{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Configure (Debug)",
      "type": "shell",
      "command": "cmake --preset debug",
      "problemMatcher": []
    },
    {
      "label": "Build (Debug)",
      "type": "shell",
      "command": "cmake --build build/debug --config Debug",
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": "$msCompile",
      "dependsOn": "Configure (Debug)"
    },
    {
      "label": "Test (Debug)",
      "type": "shell",
      "command": "ctest --output-on-failure -C Debug",
      "options": { "cwd": "${workspaceFolder}/build/debug" },
      "group": { "kind": "test", "isDefault": true },
      "problemMatcher": [],
      "dependsOn": "Build (Debug)"
    },
    {
      "label": "Configure (Release)",
      "type": "shell",
      "command": "cmake --preset release",
      "problemMatcher": []
    },
    {
      "label": "Build (Release)",
      "type": "shell",
      "command": "cmake --build build/release --config Release",
      "group": "build",
      "problemMatcher": "$msCompile",
      "dependsOn": "Configure (Release)"
    },
    {
      "label": "Test (Release)",
      "type": "shell",
      "command": "ctest --output-on-failure -C Release",
      "options": { "cwd": "${workspaceFolder}/build/release" },
      "group": "test",
      "problemMatcher": [],
      "dependsOn": "Build (Release)"
    },
    {
      "label": "WASM: Clean Data",
      "type": "shell",
      "command": "rm -f build/wasm/dithr.data",
      "windows": {
        "command": "if (Test-Path build/wasm/dithr.data) { Remove-Item build/wasm/dithr.data }"
      },
      "problemMatcher": [],
      "dependsOn": "WASM: Configure"
    },
    {
      "label": "WASM: Build",
      "type": "shell",
      "command": "cmake --build build/wasm",
      "group": "build",
      "problemMatcher": "$gcc",
      "dependsOn": "WASM: Clean Data"
    },
    {
      "label": "WASM: Configure",
      "type": "shell",
      "command": "cmake --preset wasm -DDTR_WASM_CART_DIR=${input:ExampleCartWeb}",
      "problemMatcher": []
    },
    {
      "label": "WASM: Run Example",
      "type": "shell",
      "command": "node tools/serve-wasm.js",
      "dependsOn": "WASM: Build",
      "problemMatcher": [],
      "isBackground": true
    },
    {
      "label": "WASM: Dev Example",
      "type": "shell",
      "command": "node tools/watch-wasm.js ${input:ExampleCartWeb}",
      "dependsOn": "WASM: Configure",
      "problemMatcher": [],
      "isBackground": true
    },
    {
      "label": "Run Example",
      "type": "shell",
      "command": "build/debug/dithr ${input:ExampleCart}",
      "windows": {
        "command": "build/debug/Debug/dithr.exe ${input:ExampleCart}"
      },
      "dependsOn": "Build (Debug)",
      "problemMatcher": []
    },
    {
      "label": "Coverage (Windows)",
      "type": "shell",
      "command": "if (Test-Path build/coverage-parts) { Remove-Item -Recurse build/coverage-parts }; New-Item -ItemType Directory build/coverage-parts -Force | Out-Null; foreach ($t in Get-ChildItem build/debug/tests/Debug/test_*.exe) { OpenCppCoverage --quiet --sources \"${workspaceFolder}\\src\" --export_type \"binary:build/coverage-parts/$($t.BaseName).cov\" -- $t.FullName }; $inputs = (Get-ChildItem build/coverage-parts/*.cov | ForEach-Object { '--input_coverage'; $_.FullName }); OpenCppCoverage @inputs --export_type html:build/coverage-report",
      "dependsOn": "Build (Debug)",
      "problemMatcher": [],
      "detail": "Run all tests under OpenCppCoverage and generate an HTML report in build/coverage-report/"
    }
  ],
  "inputs": [
    {
      "id": "ExampleCartWeb",
      "type": "pickString",
      "description": "Select cart to embed in WASM build",
      "options": [
        "",
        "${workspaceFolder}/examples/hello_world",
        "${workspaceFolder}/examples/sprite_animation",
        "${workspaceFolder}/examples/input_demo",
        "${workspaceFolder}/examples/tilemap",
        "${workspaceFolder}/examples/audio_demo",
        "${workspaceFolder}/examples/postfx_demo",
        "${workspaceFolder}/examples/persistence",
        "${workspaceFolder}/examples/platformer",
        "${workspaceFolder}/examples/raycaster",
        "${workspaceFolder}/examples/spritemark",
        "${workspaceFolder}/examples/ui_demo",
        "${workspaceFolder}/examples/editor",
        "${workspaceFolder}/examples/gauntlet_clone",
        "${workspaceFolder}/examples/map_demo",
        "${workspaceFolder}/examples/event_demo",
        "${workspaceFolder}/examples/transition_demo",
        "${workspaceFolder}/examples/drawlist_demo",
        "${workspaceFolder}/examples/palette_fx",
        "${workspaceFolder}/examples/collision_demo",
        "${workspaceFolder}/examples/sys_explorer",
        "${workspaceFolder}/examples/tween_showcase",
        "${workspaceFolder}/examples/synth_demo"
      ],
      "default": "examples/hello_world"
    },
    {
      "id": "ExampleCart",
      "type": "pickString",
      "description": "Select example cartridge to run",
      "options": [
        "${workspaceFolder}/examples/hello_world/cart.json",
        "${workspaceFolder}/examples/sprite_animation/cart.json",
        "${workspaceFolder}/examples/input_demo/cart.json",
        "${workspaceFolder}/examples/tilemap/cart.json",
        "${workspaceFolder}/examples/audio_demo/cart.json",
        "${workspaceFolder}/examples/postfx_demo/cart.json",
        "${workspaceFolder}/examples/persistence/cart.json",
        "${workspaceFolder}/examples/platformer/cart.json",
        "${workspaceFolder}/examples/raycaster/cart.json",
        "${workspaceFolder}/examples/spritemark/cart.json",
        "${workspaceFolder}/examples/ui_demo/cart.json",
        "${workspaceFolder}/examples/editor/cart.json",
        "${workspaceFolder}/examples/gauntlet_clone/cart.json",
        "${workspaceFolder}/examples/map_demo/cart.json",
        "${workspaceFolder}/examples/event_demo/cart.json",
        "${workspaceFolder}/examples/transition_demo/cart.json",
        "${workspaceFolder}/examples/drawlist_demo/cart.json",
        "${workspaceFolder}/examples/palette_fx/cart.json",
        "${workspaceFolder}/examples/collision_demo/cart.json",
        "${workspaceFolder}/examples/sys_explorer/cart.json",
        "${workspaceFolder}/examples/tween_showcase/cart.json",
        "${workspaceFolder}/examples/synth_demo/cart.json"
      ],
      "default": "${workspaceFolder}/examples/hello_world/cart.json"
    }
  ]
}
